# ── Contact form delivery ────────────────────────────────────────────────
# Add these keys to your existing .env (project root). SMTP is required for
# reliable delivery to iCloud — PHP mail() alone gets dropped/spam-filtered.

CONTACT_TO=ramsmandal@icloud.com

# RECOMMENDED (Hostinger mailbox): create contact@ramsmandal.com in hPanel,
# then use its credentials here. Sends authenticated as your own domain.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=ssl                 # ssl for 465, tls for 587, none for local test
SMTP_USER=contact@ramsmandal.com
SMTP_PASS=your-mailbox-password
CONTACT_FROM=contact@ramsmandal.com
CONTACT_FROM_NAME=ramsmandal.com

# ALTERNATIVE (best deliverability, free tier): Brevo / Mailgun / Postmark
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=tls
# SMTP_USER=your-brevo-login
# SMTP_PASS=your-brevo-smtp-key
