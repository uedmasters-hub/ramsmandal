# ── Contact form ─────────────────────────────────────────────────────────
# Every submission is ALWAYS saved to storage/contact-submissions.log.
# For INBOX email, pick ONE of the two paths below.

CONTACT_TO=ramsmandal@icloud.com

# PATH A — easiest, matches your working repo: send to a Gmail address.
# Shared-host mail() reaches Gmail (it's lenient); just change the line above:
#   CONTACT_TO=ramsmandal@gmail.com
# ...and leave SMTP unset.

# PATH B — keep iCloud, deliver reliably via authenticated SMTP.
# Gmail App Password (myaccount.google.com/apppasswords) — the same account
# your reference scaffolded:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=ssl
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your-16-char-app-password
# CONTACT_FROM=youraddress@gmail.com
# CONTACT_FROM_NAME=ramsmandal.com
#
# Or a Hostinger mailbox (smtp.hostinger.com / 465 / ssl / contact@ramsmandal.com).
